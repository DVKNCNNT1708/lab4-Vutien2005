{
  "info": {
    "name": "FIT4110 Lab04 Alert Notification Docker Verification",
    "description": "Postman collection for Alert Notification service - Docker packaging Lab 04",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "GET /health returns 200",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has status ok', function () { const json = pm.response.json(); pm.expect(json.status).to.eql('ok'); });",
                  "pm.test('Response has service alert-notification', function () { const json = pm.response.json(); pm.expect(json.service).to.eql('alert-notification'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /events - Create sensor event",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{authToken}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"SENSOR_READING\",\n  \"eventId\": \"evt-20260526-0001\",\n  \"deviceId\": \"sensor-temp-01\",\n  \"metric\": \"temperature\",\n  \"value\": 78.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-26T10:30:00Z\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response has eventId', function () { const json = pm.response.json(); pm.expect(json).to.have.property('eventId'); });",
                  "pm.test('Response has generatedAlertId if triggered', function () { const json = pm.response.json(); if (json.generatedAlertId) { pm.environment.set('createdAlertId', json.generatedAlertId); } pm.expect([json.generatedAlertId]).to.not.be.empty; });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/alerts - List alerts",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{authToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/alerts?limit=10&status=ACTIVE",
              "host": ["{{baseUrl}}"],
              "path": ["api", "alerts"],
              "query": [
                {"key": "limit", "value": "10"},
                {"key": "status", "value": "ACTIVE"}
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has items array', function () { const json = pm.response.json(); pm.expect(json).to.have.property('items'); pm.expect(json.items).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/alerts/{alertId} - Get alert details",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{authToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/alerts/{{createdAlertId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "alerts", "{{createdAlertId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response has alertId', function () { const json = pm.response.json(); pm.expect(json).to.have.property('alertId'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "PATCH /api/alerts/{alertId}/acknowledge",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Authorization", "value": "Bearer {{authToken}}"}
            ],
            "url": {
              "raw": "{{baseUrl}}/api/alerts/{{createdAlertId}}/acknowledge",
              "host": ["{{baseUrl}}"],
              "path": ["api", "alerts", "{{createdAlertId}}", "acknowledge"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 204 No Content', function () { pm.response.to.have.status(204); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02_Auth",
      "item": [
        {
          "name": "POST /events without token returns 401",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
