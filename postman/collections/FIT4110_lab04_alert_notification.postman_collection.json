            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.environment.get('env') === 'mock') {",
                  "  pm.test('Mock may not enforce auth', function () { pm.expect([201, 401, 500]).to.include(pm.response.code); });",
                  "} else {",
                  "  pm.test('Missing token returns 401', function () { pm.response.to.have.status(401); });",
                  "}"
                ]
              }
            }
