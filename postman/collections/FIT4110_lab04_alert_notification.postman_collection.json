            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"SENSOR_READING\",\n  \"eventId\": \"evt-20260526-0007\",\n  \"deviceId\": \"sensor-temp-01\",\n  \"metric\": \"temperature\",\n  \"value\": 81,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-26T10:36:00Z\"\n}"
            }
